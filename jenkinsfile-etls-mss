@Library('shared-libs') _

pipeline {
    environment {
        branchname =  env.BRANCH_NAME.toLowerCase()
        kubeconfig = getKubeconf(env.branchname)
        registryCredential = 'svc_jenkins'
        registryUrl = 'registryEndpoint'
        namespace = "${env.branchname == 'test' ? 'novo-pedagogico-qa' : env.branchname == 'homolog' ? 'novo-pedagogico-hom' : 'novo-pedagogico' }"
        SONAR_PROJECT = 'SME-INTEGRACAOEOL-MS-ETL'
        project = "novo-pedagogico-ms"
        TELEGRAM_CHAT_ID = 'telegramChatIdNPedagogico'
        URL_BANCO_INSTITUCIONAL = "postgresql://postgres:postgres@localhost:5432/institucional_db"
        URL_BANCO_PROFESSORES  = "postgresql://postgres:postgres@localhost:5432/professores_db"
        URL_BANCO_ALUNOS       = "postgresql://postgres:postgres@localhost:5432/alunos_db"
        URL_BANCO_PEDAGOGICO   = "postgresql://postgres:postgres@localhost:5432/pedagogico_db"
        URL_BANCO_PROGRAMAS    = "postgresql://postgres:postgres@localhost:5432/programas_db"
    
    }
    
    agent { kubernetes { 
            label 'builder-debian'
            defaultContainer 'builder-debian'
        }
    }
    
    options {
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '20'))
        disableConcurrentBuilds()
        timestamps ()
    }

    stages {

        stage('Testes') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            
            agent {
                kubernetes {
                    label 'python312'
                    defaultContainer 'python312'
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    
                    pythonTest(
                        requirementsDir: "requirements/base.txt",
                        withMigration: "true",
                        credentialEnv: "novopedagogico_env",
                        testCommand: "coverage run manage.py test"
                    )
                }
             }              
        }

        stage('SonarQube') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    
                    sonarqubePython(
                        dockerfilePath: "./Dockerfile",
                        coverageExclusions: "Dockerfile,**/testes/**,**/teste/**,cypress.config.js,**/migrations/**,config/**,docs/**,**/tests/**",
                        sonarExclusions: "**/testes/**,**/teste/**,cypress.config.js,**/migrations/**,config/**,docs/**,**/tests/**,**models.py,**views.py,**serializers.py"
                    )
                }
            }
        }

        stage("Sonar Quality Gate") {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    timeout(15) {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Dockerfile Check') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    dockerfileCheck(
                        imageName: "etl-workers",
                        dockerfilePath: "Dockerfile"
                    )
                }
            }
        }
     
        stage('Build') {
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    buildImage(
                        imageName: "etl-workers",
                        sendRegistry: "yes",
                        dockerfilePath: "Dockerfile"
                    )
                }
            }
        }

        stage('Deploy Microservices'){
            when { anyOf { branch 'master'; branch 'test'; branch 'homolog' } }
            steps {
                script{
                    env.failedStage = env.STAGE_NAME
                    if ( env.branchname == 'master' ) {
                        withCredentials([string(credentialsId: 'aprovadores-novo-pedagogico', variable: 'aprovadores')]) {
                            timeout(time: 24, unit: "HOURS") {
                                approveTelegram(env.TELEGRAM_CHAT_ID)
                                def aprovadoPor = input(message: 'Deseja realizar o deploy?', ok: 'SIM', submitter: "${aprovadores}", submitterParameter: 'APPROVED_BY')
                                env.APROVADO_POR = "${aprovadoPor}"
                                approvedTelegram(env.TELEGRAM_CHAT_ID, env.APROVADO_POR)
                            }
                        }
                    }
                    
                    echo "Deploy do etl-celery"
                    restartDeployment(
                        deploymentName: "etl-celery",
                        namespace: env.namespace
                    )

                    echo "Deploy do etl-auditoria"
                    restartDeployment(
                        deploymentName: "etl-auditoria",
                        namespace: env.namespace
                    )

                    echo "Deploy do etl-worker"
                    restartDeployment(
                        deploymentName: "etl-worker",
                        namespace: env.namespace
                    )
                }
            }
        }
     }

     post {
        always { archiveArtifacts artifacts: "coverage.xml", allowEmptyArchive: true }
        success { successTelegram(env.TELEGRAM_CHAT_ID) }
        unstable { unstableTelegram(env.TELEGRAM_CHAT_ID) }
        failure { failureTelegram(env.failedStage, env.TELEGRAM_CHAT_ID) }
        aborted { abortedTelegram(env.TELEGRAM_CHAT_ID) }
        cleanup { cleanWs() }
    }
}
