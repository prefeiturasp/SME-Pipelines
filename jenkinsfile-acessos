@Library('shared-libs') _

pipeline {
    environment {
        branchname =  env.BRANCH_NAME.toLowerCase()
        kubeconfig = getKubeconf(env.branchname)
        namespace = "${env.branchname == 'test' ? 'acessos-qa' : env.branchname == 'homolog' ? 'acessos-hom' : 'acessos-prd' }"
        registryCredential = 'jenkins_registry'
        registryUrl = 'registryEndpoint'
        flywayEnv = "${env.branchname == 'test' ? 'flyway_acessos_qa' : env.branchname == 'homolog' ? 'flyway_acessos_release' : 'flyway_acessos_master' }"
        TELEGRAM_CHAT_ID = 'telegramChatIdEMFORPEF' 
        SONAR_PROJECT = 'SME-Acessos'
        DOTNET_DEFAULT = "dotnet-10"
        project = "acessos"
    }

    agent { kubernetes { 
            label 'builder-debian'
            defaultContainer 'builder-debian'
        }
    }
    
    options {
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps ()
    }

    stages {
        stage('Testes') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['development', 'test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            parallel {
                stage('Integracao') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-coverage",
                            projectPath: "teste/SME.Acessos.TesteIntegracao",
                            stashName: "integracao",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }

                stage('Unitarios') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-coverage",
                            projectPath: "teste/SME.Acessos.TesteUnitario",
                            stashName: "unitarios",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }
            }
        }

        stage('SonarQube') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['development', 'test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    unstash 'integracao'
                    unstash 'unitarios'
                    
                    sonarqubeDotnet(
                        dotnetVersion: env.DOTNET_DEFAULT,
                        coverageType: "dotnet-coverage",
                        project: "src/SME.Acessos.Api/SME.Acessos.Api.csproj",
                        coverageExclusions: "**/teste/**,**/*Dto.cs,**/*ViewModel.cs,**/Migrations/**,**/Controllers/**",
                        sonarExclusions: "teste/**,**/Migrations/**,**/Configurations/**,**/*Dto.cs,**/*ViewModel.cs,**/Startup.cs,**/Program.cs"
                    )
                }
            }
        }

        stage("Sonar Quality gate") {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    timeout(15) {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Dockerfile Check') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['development'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    dockerfileCheck(
                        imageName: "sme-acessos",
                        dockerfilePath: "src/SME.Acessos.Api/Dockerfile"
                    )
                }
            }
        }

        stage('Build') {
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    buildImage(
                        imageName: "sme-acessos",
                        sendRegistry: "yes",
                        dockerfilePath: "src/SME.Acessos.Api/Dockerfile"
                    )
                }
            }
        }

        stage('Deploy') {
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } } 
            steps {
                script{
                    env.failedStage = env.STAGE_NAME
                    if ( env.branchname == 'master' ) {
                        withCredentials([string(credentialsId: 'aprovadores-sgp', variable: 'aprovadores')]) {
                            timeout(time: 24, unit: "HOURS") {
                                approveTelegram(env.TELEGRAM_CHAT_ID)
                                def aprovadoPor = input(message: 'Deseja realizar o deploy?', ok: 'SIM', submitter: "${aprovadores}", submitterParameter: 'APPROVED_BY')
                                env.APROVADO_POR = "${aprovadoPor}"
                                approvedTelegram(env.TELEGRAM_CHAT_ID, env.APROVADO_POR)
                            }
                        }
                    }
                    
                    restartDeployment(
                        deploymentName: "sme-acessos",
                        namespace: env.namespace
                    )
                }
            }
        }

        stage('Flyway') {
            agent { kubernetes { 
                    label 'flyway'
                    defaultContainer 'flyway'
                }
            }
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } }
            steps{
                script {
                    failedStage = env.STAGE_NAME
                    withCredentials([string(credentialsId: "${env.flywayEnv}", variable: 'url')]) {
                        sh 'pwd'
                        sh 'ls $(pwd)/scripts'
                        sh 'flyway -X -url=$url -locations="filesystem:scripts" -outOfOrder=true migrate'
                    }
                }
            }      
        }
    }

    post {
        always { archiveArtifacts artifacts: "**/coverage.opencover.xml", allowEmptyArchive: true }
        success { successTelegram(env.TELEGRAM_CHAT_ID) }
        unstable { unstableTelegram(env.TELEGRAM_CHAT_ID) }
        failure { failureTelegram(env.failedStage, env.TELEGRAM_CHAT_ID) }
        aborted { abortedTelegram(env.TELEGRAM_CHAT_ID) }
        cleanup { cleanWs() }
    }
}