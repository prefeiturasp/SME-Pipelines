@Library('shared-libs') _

pipeline {
    environment {
        branchname =  env.BRANCH_NAME.toLowerCase()
        kubeconfig = getKubeconf(env.branchname)
        namespace = "${env.branchname == 'test' ? 'serap-itens-testes' : env.branchname == 'homolog' ? 'serap-itens-hom' : 'serap-itens' }"
        registryCredential = 'svc_jenkins'
        registryUrl = 'registryEndpoint'
        TELEGRAM_CHAT_ID = 'telegramChatIdTest' 
        SONAR_PROJECT = "SME-Prova-Serap-Itens-api"
        DOTNET_DEFAULT = "dotnet-10"
        project = "serap"
    }

    agent { kubernetes { 
            label 'builder-debian'
            defaultContainer 'builder-debian'
        }
    }
    
    options {
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps ()
    }

    stages {
        stage('Testes') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            parallel {
                stage('aplicacao') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-coverage",
                            projectPath: "teste/SME.SERAp.Prova.Item.Aplicacao.Teste",
                            stashName: "aplicacao",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }

                stage('dados') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-coverage",
                            projectPath: "teste/SME.SERAp.Prova.Item.Dados.Teste",
                            stashName: "dados",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }

                stage('dominio') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-coverage",
                            projectPath: "teste/SME.SERAp.Prova.Item.Dominio.Teste",
                            stashName: "dominio",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }

                stage('infra') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-coverage",
                            projectPath: "teste/SME.SERAp.Prova.Item.Infra.Teste",
                            stashName: "infra",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }
            }
        }

        stage('SonarQube') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    
                    unstash 'aplicacao'
                    unstash 'dados'
                    unstash 'dominio'
                    unstash 'infra'
                    
                    sonarqubeDotnet(
                        dotnetVersion: env.DOTNET_DEFAULT,
                        coverageType: "dotnet-coverage",
                        project: "src/SME.SERAp.Prova.Item.Api/SME.SERAp.Prova.Item.Api.csproj",
                        coverageExclusions: "Dockerfile.dev,teste/**,**/*Dto.cs,**/*ViewModel.cs,**/Migrations/**",
                        sonarExclusions: "Dockerfile.dev,teste/**,**/Configurations/**,**/*Dto.cs,**/*ViewModel.cs,**/Startup.cs,**/Program.cs"
                    )
                }
            }
        }

        stage("Sonar Quality gate") {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    timeout(15) {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Dockerfile Check') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    dockerfileCheck(
                        imageName: "serap-itens-api",
                        dockerfilePath: "src/SME.SERAp.Prova.Item.Api/Dockerfile"
                    )
                }
            }
        }

        stage('Build') {
            when { anyOf { branch 'master'; branch 'main'; branch 'homolog'; branch 'test'; } }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    buildImage(
                        imageName: "serap-itens-api",
                        sendRegistry: "yes",
                        dockerfilePath: "src/SME.SERAp.Prova.Item.Api/Dockerfile"
                    )
                }
            }
        }

        stage('Deploy') {
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } } 
            steps {
                script{
                    env.failedStage = env.STAGE_NAME
                    if ( env.branchname == 'main' ||  env.branchname == 'master' ) {
                        withCredentials([string(credentialsId: 'aprovadores-prova-serap-itens', variable: 'aprovadores')]) {
                            timeout(time: 24, unit: "HOURS") {
                                approveTelegram(env.TELEGRAM_CHAT_ID)
                                def aprovadoPor = input(message: 'Deseja realizar o deploy?', ok: 'SIM', submitter: "${aprovadores}", submitterParameter: 'APPROVED_BY')
                                env.APROVADO_POR = "${aprovadoPor}"
                                approvedTelegram(env.TELEGRAM_CHAT_ID, env.APROVADO_POR)
                            }
                        }
                    }
                    
                    restartDeployment(
                        deploymentName: "serap-itens-api",
                        namespace: env.namespace
                    )
                }
            }
        }

        stage('Flyway') { 
            agent { kubernetes { 
                    label 'flyway'
                    defaultContainer 'flyway'
                }
            }
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } }    
            steps{
                script {
                    env.failedStage = env.STAGE_NAME
                    withCredentials([file(credentialsId: "flyway_serapitens_${branchname}", variable: 'env')]) {
                        sh 'rm -rf flyway/flyway.conf'
                        sh 'mkdir -p flyway'
                        sh 'touch flyway/flyway.conf'
                        sh 'cp "$env" "flyway/flyway.conf"'
                        sh 'flyway -configFiles=flyway/flyway.conf -locations="filesystem:scripts" -X repair'
                        sh 'flyway -configFiles=flyway/flyway.conf -locations="filesystem:scripts" -outOfOrder=true migrate'
                    }
                }
            }
        }
    }

    post {
        // always { archiveArtifacts artifacts: "**/coverage.opencover.xml", allowEmptyArchive: true }
        success { successTelegram(env.TELEGRAM_CHAT_ID) }
        unstable { unstableTelegram(env.TELEGRAM_CHAT_ID) }
        failure { failureTelegram(env.failedStage, env.TELEGRAM_CHAT_ID) }
        aborted { abortedTelegram(env.TELEGRAM_CHAT_ID) }
        cleanup { cleanWs() }
    }
}