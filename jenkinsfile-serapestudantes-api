@Library('shared-libs') _

pipeline {
    environment {
        branchname =  env.BRANCH_NAME.toLowerCase()
        kubeconfig = getKubeconf(env.branchname)
        namespace = "${env.branchname == 'release' ? 'serap-boletim-hom' : env.branchname == 'test' ? 'serap-boletim-testes' : 'serap-boletim' }" 
        deployment = "${env.branchname == 'release' ? 'prova-serap-api' : 'sme-prova-serap-api' }"
        registryCredential = 'svc_jenkins'
        registryUrl = 'registryEndpoint'
        TELEGRAM_CHAT_ID = 'telegramChatIdTest' 
        SONAR_PROJECT = 'SME-prova-serap-api'
        dotnetVersion = "${env.branchname == 'release' ? 'dotnet-8' : 'dotnet-5'}"
        DOTNET_DEFAULT = "${env.dotnetVersion}"
    }

    agent { kubernetes { 
            label 'builder-debian'
            defaultContainer 'builder-debian'
        }
    }
    
    options {
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps ()
    }

    stages {
        stage('Testes') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'release'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'release', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            parallel {
                stage('ApiTeste') {
                    agent { kubernetes { label 'builder-debian'; defaultContainer 'builder-debian' } }
                    steps {
                        testDotnet([
                            testTool: "dotnet-test",
                            projectPath: "teste/SME.SERAp.Aplicacao.Test",
                            stashName: "aplicacao",
                            dotnetVersion: env.DOTNET_DEFAULT
                        ])
                    }
                }
            }
        }

        stage('SonarQube') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'release'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'release', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    unstash 'aplicacao'
                    
                    sonarqubeDotnet(
                        dotnetVersion: env.DOTNET_DEFAULT,
                        coverageType: "dotnet-coverage",
                        project: "./src/SME.SERAp.Prova.Api/SME.SERAp.Prova.Api.csproj",
                        coverageExclusions: "**/teste/**,**/*Dto.cs,**/*ViewModel.cs,**/Migrations/**",
                        sonarExclusions: "teste/**,**/Configurations/**,**/*Dto.cs,**/*ViewModel.cs,**/Startup.cs,**/Program.cs"
                    )
                }
            }
        }

        stage("Sonar Quality gate") {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'release'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    timeout(15) {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Dockerfile Check') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'release'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    dockerfileCheck(
                        imageName: "sme-prova-serap-api",
                        dockerfilePath: "src/SME.SERAp.Prova.Api/Dockerfile"
                    )
                }
            }
        }

        stage('Build') {
            when { anyOf { branch 'master'; branch 'main'; branch 'release'; branch 'test'; } }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    buildImage(
                        imageName: "sme-prova-serap-api",
                        sendRegistry: "yes",
                        dockerfilePath: "src/SME.SERAp.Prova.Api/Dockerfile"
                    )
                }
            }
        }

        stage('Deploy') {
            when { anyOf { branch 'master'; branch 'release'; branch 'test'; } } 
            steps {
                script{
                    env.failedStage = env.STAGE_NAME
                    if ( env.branchname == 'main' ||  env.branchname == 'master' ) {
                        withCredentials([string(credentialsId: 'aprovadores-serap', variable: 'aprovadores')]) {
                            timeout(time: 24, unit: "HOURS") {
                                approveTelegram(env.TELEGRAM_CHAT_ID)
                                def aprovadoPor = input(message: 'Deseja realizar o deploy?', ok: 'SIM', submitter: "${aprovadores}", submitterParameter: 'APPROVED_BY')
                                env.APROVADO_POR = "${aprovadoPor}"
                                approvedTelegram(env.TELEGRAM_CHAT_ID, env.APROVADO_POR)
                            }
                        }
                    }
                    
                    restartDeployment(
                        deploymentName: "sme-prova-serap-api",
                        namespace: env.namespace
                    )
                }
            }
        }
    }

    post {
        // always { archiveArtifacts artifacts: "**/coverage.opencover.xml", allowEmptyArchive: true }
        success { successTelegram(env.TELEGRAM_CHAT_ID) }
        unstable { unstableTelegram(env.TELEGRAM_CHAT_ID) }
        failure { failureTelegram(env.failedStage, env.TELEGRAM_CHAT_ID) }
        aborted { abortedTelegram(env.TELEGRAM_CHAT_ID) }
        cleanup { cleanWs() }
    }
}