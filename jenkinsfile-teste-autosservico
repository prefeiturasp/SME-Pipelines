@Library('shared-libs') _

pipeline {
    environment {
        branchname =  env.BRANCH_NAME.toLowerCase()
    }
    
    agent { kubernetes { 
            label 'builder-debian'
            defaultContainer 'builder-debian'
        }
    }
    
    options {
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '20'))
        disableConcurrentBuilds()
        timestamps ()
    }

    stages {
        stage('Build') {
            when { anyOf { branch 'master'; branch 'homolog'; branch 'test'; } }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    echo "Rodando build..."
                }
            }
        }

        stage('Aprovação PO'){
            when { anyOf { branch 'master'; branch 'main';} }
            steps {
                script{
                    env.failedStage = env.STAGE_NAME

                    withCredentials([
                        string(credentialsId: 'aprovadores-teste', variable: 'APROVADORES_POS')
                    ]) {

                        def usuario = input(
                            message: 'Aprovação para Produção',
                            ok: 'Aprovar',
                            parameters: [
                                string(
                                    name: 'Usuario',
                                    defaultValue: '',
                                    description: 'Nome do aprovador'
                                )
                            ]
                        )

                        def listaAprovadores = APROVADORES_POS
                            .split(',')
                            .collect { it.trim() }

                        if (!listaAprovadores.contains(usuario)) {
                            error("Usuário '${usuario}' não está autorizado a aprovar deploy em produção.")
                        }

                        env.APROVADO_POR = usuario
                        echo "Aprovado por ${usuario}"
                    }
                }
            }
        }

        stage('Deploy'){
            when { anyOf { branch 'master'; branch 'test'; branch 'homolog' } }
            steps {
                script{
                    env.failedStage = env.STAGE_NAME
                    if ( env.branchname == 'main' ||  env.branchname == 'master' ) {
                        withCredentials([string(credentialsId: 'aprovadores-teste', variable: 'aprovadores')]) {
                            timeout(time: 24, unit: "HOURS") {
                                def aprovadoPor = input(message: 'Deseja realizar o deploy?', ok: 'SIM', submitter: "${aprovadores}", submitterParameter: 'APPROVED_BY')
                                env.APROVADO_POR = "${aprovadoPor}"
                            }
                        }
                    }
                    
                    echo "Aprovado por: ${env.APROVADO_POR}"
                    echo "Rodando deploy.."
                }
            }
        }
     }

     post {
        cleanup { cleanWs() }
    }
}
