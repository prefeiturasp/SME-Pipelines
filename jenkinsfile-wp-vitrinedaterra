@Library('shared-libs') _

pipeline {
    environment {
        branchname =  env.BRANCH_NAME.toLowerCase()
        kubeconfig = 'config_wordpress'
        namespace = "${env.branchname == 'test' ? 'qa-vitrinedaterra' : env.branchname == 'homolog' ? 'hom-vitrinedaterra' : 'prod-vitrinedaterra' }"
        registryCredential = 'jenkins_registry'
        registryUrl = 'registryEndpoint'
        TELEGRAM_CHAT_ID = 'telegramChatIdWordpress'
        SONAR_PROJECT = 'SME-VITRINEDATERRA'
        project = "vitrinedaterra"
    }
  
    agent { kubernetes { 
            label 'builder-debian'
            defaultContainer 'builder-debian'
        }
    }

    options {
        ansiColor('xterm')
        timestamps ()
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '5'))
        disableConcurrentBuilds()
    }
  
    stages {
        stage('SonarQube') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    } else {
                        return ['test', 'homolog', 'master'].contains(env.BRANCH_NAME)
                    }
                }
            }
            steps {
                script {
                    failedStage = env.STAGE_NAME
                    sonarqubePhp(
                        dockerfilePath: "Dockerfile",
                        coverageExclusions: "Dockerfile**,**/testes/**,cypress.config.js",
                        sonarExclusions: "**/testes/**,cypress.config.js ",
                        sources: "wp-content/themes/,wp-admin/,wp-includes/"
                    )
                }
            }
        }

        stage("Sonar Quality Gate") {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    timeout(15) {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Dockerfile Check') {
            when {
                expression {
                    if (env.BRANCH_NAME.startsWith('PR-')) {
                        return ['test', 'homolog'].contains(env.CHANGE_TARGET)
                    }
                }
            }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    dockerfileCheck(
                        imageName: "vitrinedaterra-php-fpm",
                        dockerfilePath: "Dockerfile"
                    )
                }
            }
        }

        stage('Build') {
            when { anyOf { branch 'test'; branch 'homolog'; branch 'master'; } }
            steps {
                script {
                    env.failedStage = env.STAGE_NAME
                    
                    buildImage(
                        imageName: "vitrinedaterra-php-fpm",
                        sendRegistry: "yes",
                        dockerfilePath: "Dockerfile"
                    )
                }
            }
        }
        
        stage('Deploy QA'){
            when { anyOf {  branch 'test'; } }
            agent { kubernetes { 
                    label 'devops-tools'
                    defaultContainer 'devops-tools'
                }
            }   
            steps {
                script{                 
                    env.failedStage = env.STAGE_NAME
                    
                    restartDeployment(
                        deploymentName: "qa-vitrinedaterra",
                        namespace: env.namespace
                    )
                }
            }           
        }

        stage('Deploy Hom'){
            when { anyOf {  branch 'homolog'; } }
            agent { kubernetes { 
                    label 'devops-tools'
                    defaultContainer 'devops-tools'
                }
            }   
            steps {
                script{                 
                    env.failedStage = env.STAGE_NAME
                    
                    restartDeployment(
                        deploymentName: "hom-vitrinedaterra",
                        namespace: env.namespace
                    )
                }
            }           
        }

        stage('Deploy Prod'){
            when { anyOf {  branch 'master'; } }
            agent { kubernetes { 
                    label 'devops-tools'
                    defaultContainer 'devops-tools'
                }
            }   
            steps {
                script{                 
                    env.failedStage = env.STAGE_NAME
                    if ( env.branchname == 'master' ) {
                        withCredentials([string(credentialsId: 'aprovadores-wordpress', variable: 'aprovadores')]) {
                            timeout(time: 24, unit: "HOURS") {
                                approveTelegram(env.TELEGRAM_CHAT_ID)
                                def aprovadoPor = input(message: 'Deseja realizar o deploy?', ok: 'SIM', submitter: "${aprovadores}", submitterParameter: 'APPROVED_BY')
                                env.APROVADO_POR = "${aprovadoPor}"
                                approvedTelegram(env.TELEGRAM_CHAT_ID, env.APROVADO_POR)
                            }
                        }
                    }
                    
                    restartDeployment(
                        deploymentName: "prod-vitrinedaterra",
                        namespace: env.namespace
                    )
                }
            }
        }
    }

    post {
        // always { archiveArtifacts artifacts: "coverage.xml", allowEmptyArchive: true }
        success { successTelegram(env.TELEGRAM_CHAT_ID) }
        unstable { unstableTelegram(env.TELEGRAM_CHAT_ID) }
        failure { failureTelegram(env.failedStage, env.TELEGRAM_CHAT_ID) }
        aborted { abortedTelegram(env.TELEGRAM_CHAT_ID) }
        cleanup { cleanWs() }
    }
}